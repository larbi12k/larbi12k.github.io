<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>حاسبة العمر | ToolVerse</title>

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{

background:linear-gradient(135deg,#0f172a,#1e293b);

display:flex;

justify-content:center;

align-items:center;

height:100vh;

color:white;

}

.box{

background:#1f2937;

padding:40px;

border-radius:20px;

width:350px;

text-align:center;

box-shadow:0 0 30px rgba(0,0,0,.4);

}

h1{

margin-bottom:20px;

}

input{

width:100%;

padding:15px;

margin:15px 0;

border:none;

border-radius:10px;

font-size:18px;

}

button{

width:100%;

padding:15px;

border:none;

border-radius:10px;

background:#3b82f6;

color:white;

font-size:18px;

cursor:pointer;

}

button:hover{

background:#2563eb;

}

#result{

margin-top:20px;

font-size:22px;

font-weight:bold;

}

a{

display:inline-block;

margin-top:20px;

color:#38bdf8;

text-decoration:none;

}

</style>

</head>

<body>

<div class="box">

<h1>🎂 حاسبة العمر</h1>

<input type="date" id="birth">

<button onclick="calcAge()">

احسب العمر

</button>

<div id="result">

</div>

<a href="../index.html">

⬅ العودة للرئيسية

</a>

</div>

<script>

function calcAge(){

let birth=new Date(document.getElementById("birth").value);

let today=new Date();

let age=today.getFullYear()-birth.getFullYear();

let month=today.getMonth()-birth.getMonth();

if(month<0||month===0&&today.getDate()<birth.getDate()){

age--;

}

document.getElementById("result").innerHTML=

"عمرك هو "+age+" سنة 🎉";

}

</script>

</body>

</html>
